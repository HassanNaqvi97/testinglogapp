{
  "version": "2.0",
  "extensions": {
    "serviceBus": {
      "prefetchCount": 0,
      "messageHandlerOptions": {
        "autoCompleteMessages": true,
        "maxConcurrentCalls": 4,
        "maxAutoLockRenewalDuration": "00:05:00"
      }
    }
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Host.Results": "Information",
      "Function": "Information"
    }
  }
}
